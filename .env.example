# Common MCP auth (runtime -> MCP)
MCP_JWT_ISS=openclaw-runtime
MCP_JWT_AUD=agentic-mcp
# RS256 public key (PEM). In prod, mount this as a secret.
MCP_JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\nREPLACE_ME\n-----END PUBLIC KEY-----"

# Request limits
MCP_MAX_BODY_BYTES=1048576
MCP_LOG_LEVEL=INFO

# Attachment downloading (signed URL only)
ATTACHMENT_ALLOWED_HOSTS=cdn.example.com,storage.example.com
ATTACHMENT_MAX_BYTES=5242880
ATTACHMENT_TIMEOUT_SECONDS=10

# =========================
# Domain backends (MCP -> backend)
# =========================

# Payments
PAYMENTS_BASE_URL=http://host.docker.internal:9001
PAYMENTS_API_KEY=replace_me
PAYMENTS_TIMEOUT_SECONDS=10

# Ticketing
TICKETING_BASE_URL=http://host.docker.internal:9002
TICKETING_API_KEY=replace_me
TICKETING_TIMEOUT_SECONDS=10

# CRM
CRM_BASE_URL=http://host.docker.internal:9003
CRM_API_KEY=replace_me
CRM_TIMEOUT_SECONDS=10

# KYC
KYC_BASE_URL=http://host.docker.internal:9004
KYC_API_KEY=replace_me
KYC_TIMEOUT_SECONDS=15

# Fraud
FRAUD_BASE_URL=http://host.docker.internal:9005
FRAUD_API_KEY=replace_me
FRAUD_TIMEOUT_SECONDS=15

# Notifications
NOTIFICATION_BASE_URL=http://host.docker.internal:9006
NOTIFICATION_API_KEY=replace_me
NOTIFICATION_TIMEOUT_SECONDS=10

# Escalation
ESCALATION_BASE_URL=http://host.docker.internal:9007
ESCALATION_API_KEY=replace_me
ESCALATION_TIMEOUT_SECONDS=10

# Onboarding
ONBOARDING_BASE_URL=http://host.docker.internal:9008
ONBOARDING_API_KEY=replace_me
ONBOARDING_TIMEOUT_SECONDS=10

# Loans/Collections
LOANS_BASE_URL=http://host.docker.internal:9009
LOANS_API_KEY=replace_me
LOANS_TIMEOUT_SECONDS=10

# Compliance
COMPLIANCE_BASE_URL=http://host.docker.internal:9010
COMPLIANCE_API_KEY=replace_me
COMPLIANCE_TIMEOUT_SECONDS=10

# RAG (Chroma)
RAG_CHROMA_PERSIST_DIR=/data/chroma
RAG_CHROMA_COLLECTION=agentic_rag
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_DEFAULT_VISIBILITY=public

# Compliance regulatory web check (default-deny)
REG_WEB_ALLOWED_HOSTS=cbn.gov.ng
REG_WEB_SEED_URLS=https://www.cbn.gov.ng/
REG_WEB_TIMEOUT_SECONDS=10
REG_WEB_MAX_BYTES=2000000
